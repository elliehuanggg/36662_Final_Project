# Cleaning & Feature Engineering

Apply the same cleaning to every data frame so train and test always match.
Add new feature ideas here and they'll propagate automatically.

```{r clean-fn}
clean_flights <- function(df) {
  df |>
    mutate(
      # date
      fl_date = as.Date(fl_date),

      # departure hour from scheduled time (dep_time is NA in guess rows — that's fine)
      sched_dep_hour = floor(crs_dep_time / 100),
      dep_hour       = floor(dep_time / 100),

      # calendar
      month       = factor(month, levels = 1:12),
      day_of_week = factor(day_of_week, levels = 1:7,
                           labels = c("Mon","Tue","Wed","Thu","Fri","Sat","Sun")),

      # target (numeric for modelling)
      dep_del15 = as.numeric(dep_del15),

      # key categoricals
      op_unique_carrier = factor(op_unique_carrier),
      origin            = factor(origin),
      dest              = factor(dest)
    )
}

flights_2023         <- clean_flights(flights_2023)
flights_2024         <- clean_flights(flights_2024)
flights_test_all     <- clean_flights(flights_test_all)
flights_test_visible <- clean_flights(flights_test_visible)
flights_test_guess   <- clean_flights(flights_test_guess)
```

