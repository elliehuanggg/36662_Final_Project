# Data Validation

Sanity checks before modelling. These should all pass silently — investigate
anything that prints a warning.

```{r validate}
# target is 0/1 with no unexpected values
stopifnot(all(train$dep_del15 %in% c(0, 1), na.rm = TRUE))
cat("✓ dep_del15 is 0/1\n")

# leakage check — these fields should all be NA in the guess set
leakage_cols <- c("dep_time", "dep_delay", "dep_delay_new", "dep_del15",
                  "taxi_out", "wheels_off", "arr_time", "arr_delay",
                  "cancelled", "actual_elapsed_time", "carrier_delay",
                  "weather_delay", "nas_delay", "late_aircraft_delay")

leaked <- leakage_cols[
  leakage_cols %in% names(test_guess) &
  sapply(leakage_cols, \(col) !all(is.na(test_guess[[col]])))
]
if (length(leaked) == 0) cat("✓ no leakage columns populated in test_guess\n") else
  warning("leakage found: ", paste(leaked, collapse = ", "))

# missing target rate and date coverage
cat(sprintf("  missing dep_del15 in train: %d (%.2f%%)\n",
            sum(is.na(train$dep_del15)),
            100 * mean(is.na(train$dep_del15))))
cat(sprintf("  train: %s to %s\n", min(train$fl_date), max(train$fl_date)))
cat(sprintf("  test_guess: %s to %s\n", min(test_guess$fl_date), max(test_guess$fl_date)))
```

